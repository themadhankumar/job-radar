# Neon Postgres connection string (pooled)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# 32+ char random secret for session JWTs:  openssl rand -hex 32
AUTH_SECRET=change-me
# 32-byte hex key for encrypting stored API keys:  openssl rand -hex 32
ENCRYPTION_KEY=change-me
# Shared fallback Anthropic key (BYOK users override in Settings)
ANTHROPIC_API_KEY=sk-ant-...
