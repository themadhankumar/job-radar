# Local pipeline env — copy to `pipeline/.env` and fill in real values.
# `.env` is gitignored; never commit real secrets. main.py auto-loads this
# file via python-dotenv. Same values as the GitHub Actions secrets.

# Neon connection string (include ?sslmode=require)
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Fernet key used to decrypt per-user BYOK keys / Notion tokens (Actions secret)
ENCRYPTION_KEY=

# Shared Anthropic key — powers pay/YoE enrichment + company classification.
# Optional (those steps no-op without it), but include it so local runs enrich
# and classify the same way Actions does.
ANTHROPIC_API_KEY=
